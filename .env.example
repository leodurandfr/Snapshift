# Database
DATABASE_URL=postgresql+asyncpg://snapshift:snapshift@localhost:5433/snapshift

# API Security
API_TOKEN=change-me-to-a-random-secret-token

# Storage
STORAGE_PATH=./storage

# Capture defaults
DEFAULT_COMPRESSION=light
CAPTURE_TIMEOUT=30
DEFAULT_RETENTION_DAYS=90

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
